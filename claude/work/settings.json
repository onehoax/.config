  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || true); [[ \"$branch\" == \"staging\" || \"$branch\" == \"master\" || \"$branch\" == \"main\" ]] && echo \"Blocked: edits are not allowed on $branch\" && exit 2'"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.config/claude/statusline-command.sh"
  },
  "syntaxHighlightingDisabled": false,
  "effortLevel": "high",
  "tui": "fullscreen",
  "theme": "dark",
  "switchModelsOnFlag": false
}
