{
  "permissions": {
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(.env)",
      "Read(./secrets/**)",
      "Read(/**/*.pem)",
      "Bash(curl *)",
      "Bash(rm -rf *)"
    ]
  },
  "model": "sonnet",
  "statusLine": {
    "type": "command",
    "command": "bash ~/.config/claude/statusline-command.sh"
  },
  "effortLevel": "medium",
  "tui": "fullscreen",
  "theme": "dark",
  "switchModelsOnFlag": false,
  "useAutoModeDuringPlan": false
}
